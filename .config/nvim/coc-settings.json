{
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "javascriptreact",
    "html",
    "yaml",
    "json",
    "python",
    "typescriptreact",
    "typescript",
    "htmldjango"
  ],
  "htmldjango.formatting.provider": "djhtml",
  "htmldjango.completion.enable": false,
  "snippets.snipmate.enable": false,
  "htmldjango.djhtml.tabWidth": 2,
  "python.linting.enabled": true,
  "python.linting.flake8Enabled": true,
  "python.linting.flake8Path": "~/.local/bin/flake8",
  "python.formatting.autopep8Path": "~/.local/bin/autopep8",
  "python.formatting.provider": "autopep8",
  "pyright.disableDiagnostics": true,
  "prettier.formatterPriority": 1,
  "snippets.extends": {
    "javascriptreact": ["javascript", "html"],
    "typescript": ["javascript", "html"]
  }
}
