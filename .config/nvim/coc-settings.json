{
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "javascriptreact",
    "html",
    "yaml",
    "json",
    "python",
    "typescriptreact",
    "typescript",
    "htmldjango"
  ],
  "htmldjango.formatting.provider": "djhtml",
  "tsserver.formatOnType": false,
  "typescript.format.semicolons": "insert",
  "javascript.format.semicolons": "insert",
  "htmldjango.completion.enable": false,
  "snippets.snipmate.enable": false,
  "htmldjango.djhtml.tabWidth": 2,
  "python.linting.enabled": false,
  "python.formatting.autopep8Path": "~/.local/bin/autopep8",
  "python.formatting.provider": "autopep8",
  "snippets.extends": {
    "javascriptreact": [
      "html"
    ],
    "typescriptreact": [
      "html"
    ]
  },
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true
}
