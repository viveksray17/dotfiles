{
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "javascriptreact",
    "html",
    "yaml",
    "json",
    "python",
    "typescriptreact",
    "typescript"
  ],
  "python.formatting.provider": "autopep8",
  "snippets.extends": {
    "javascriptreact": ["javascript", "html"],
    "typescript": ["javascript", "html"]
  }
}
