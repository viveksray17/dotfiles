# terminal emulator
super + Return
    st
# program launcher
super + p
	dmenu_run -p "Run:"
# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd && notify-send "SXHKD" "Program Reloaded"

# Shortcut for Applications
super + {e,w,v,shift+v,super+control+l}
    {pcmanfm /data/vivek,firefox,codium,pavucontrol,slock}
super + alt + {w,n}
    st -e {nmtui,nvim}
super + shift + t
    sxiv /data/vivek/Downloads/School/Extra/IMG-20210609-WA0009.jpg -Z

# Sound
{XF86AudioRaiseVolume,XF86AudioLowerVolume}
    pactl set-sink-volume 0 {+5%,-5%};polybar-msg hook volume 2;notify-send "Pipewire" "Volume Set to $($HOME/.config/polybar/scripts/get-volume)"
XF86AudioMute
    pactl set-sink-volume 0 0%;polybar-msg hook volume 3;notify-send "Pipewire" "Volume Muted"
shift+XF86AudioMute
    pactl set-sink-volume 0 50%;polybar-msg hook volume 2;notify-send "Pipewire" "Volume Set to $($HOME/.config/polybar/scripts/get-volume)"

# Screenshots with scrot
Print
    scrot -q 100 -p /data/vivek/Pictures/Screenshots/screenshot_%Y-%m-%d_%T.png;notify-send "Scrot" "Full-Screen Captured"
super + Print
    scrot -q 100 -u -p /data/vivek/Pictures/Screenshots/screenshot_%Y-%m-%d_%T.png;notify-send "Scrot" "Window Captured"
shift + Print
    scrot -q 100 -s -p /data/vivek/Pictures/Screenshots/screenshot_%Y-%m-%d_%T.png;notify-send "Scrot" "Area Captured"

# Poweroff and Reboot
super + shift + {b,q}
    {reboot,poweroff}

# BSPWM hotkeys
# restart bspwm
super + shift + r
	bspc wm -r

# close and kill
super + shift + c
	bspc node -c

# set the window state
super + {t,shift+t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus or send to the given desktop
super + {_,shift + }{1-5}
	bspc {desktop -f,node -d} '^{1-5}'


# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}
