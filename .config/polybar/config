[colors]
background = #222
background-alt = #444
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
alert = #bd2c40

[bar/bar]
enable-ipc = true
width = 100%
height = 27
radius = 0
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3
border-size = 0
padding-left = 0
padding-right = 1
module-margin-left = 1
module-margin-right = 1
font-0 = JetBrains Mono:size=10:antialias=true:style=bold
font-1 = Noto Color Emoji:fontformat=truetype:scale=10:antialias=true
modules-left = bspwm
modules-right = volume ssid kernel packages date
tray-position = right
tray-padding = 2
cursor-click = pointer
cursor-scroll = ns-resize
wm-restack = bspwm

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 2

[module/date]
type = custom/script
exec = date '+%d-%m-%Y %H:%M'
interval = 60
format-prefix = "📅 "
format-underline = #0a6cf5
format-padding = 1

[module/kernel]
type = custom/ipc
format-prefix = "🐧 "
hook-0 = uname -r
format-underline = #00a0d1
format-padding = 1
initial = 1

[module/packages]
type = custom/ipc
hook-0 = pacman -Q | wc -l
format-prefix = "📦 "
click-left = polybar-msg hook packages 1
format-underline = #00d134
format-padding = 1
initial = 1

[module/ssid]
type = custom/ipc
hook-0 = ~/.config/polybar/scripts/get-ssid
format-prefix = "📶(SSID) "
click-left = st -e nmtui
click-right = polybar-msg hook ssid 1
format-underline = ${colors.secondary}
format-padding = 1
initial = 1

[module/volume]
type = custom/ipc
hook-0 = echo "50"
hook-1 = ~/.config/polybar/scripts/get-volume
hook-2 = echo "muted"
click-left = pavucontrol
format-prefix = "VOLUME "
format-underline = #0a6cf5
format-padding = 1
initial = 1
