#!/bin/sh
# ALIASES FOR GIT
alias \
    gs="git status" \
    ga="git add" \
    gc="git commit" \
    gp="git push origin main" \
    gd="git diff" \
    gr="git remote -v" \
    gch="git checkout" \
    gl="git log" \
    gra="git remote add origin" \
    grv="git remote remove origin" \
    gi="git init"

# ALIASES FOR CONFIG
alias \
    cs="config status" \
    ca="config add" \
    cc="config commit" \
    cps="config push origin main" \
    cdf="config diff"

# EXTRA
alias \
    ls='ls --color=auto' \
    ll='ls -al --color=auto' \
    mi='sudo make clean install' \
    sc="cd ~/.local/bin" \
    dw="cd ~/suckless/dwm" \
    sk="cd ~/suckless" \
    mv="mv -i" \
    cp="cp -i" \
    rm="rm -i" \
    config="/usr/bin/git --git-dir=$HOME/.dotfiles.git/ --work-tree=$HOME" \
    update="yay -Syyu;firefox-updater" \
    find="find -name 2> /dev/null" \
    py="cd ~/Documents/code/python" \
    ac="source env/bin/activate" \
    tmux="tmux -f $HOME/.config/tmux.conf"

se(){ 
    directory=$(du -a $HOME/.local/bin/* $HOME/.local/share/bookmarks $HOME/.config/* | awk '{ print $2 }' | grep -w -v "libreoffice" | fzf)
    [ "$directory" ] && nvim $directory
}
de() { 
    dir=$(ls -d -1 "$HOME/Documents/code/django/"* "$HOME/Documents/code/projects/"* | fzf)
    name=$(echo $dir | awk -F "/" '{ print $NF }')
    [ "$dir" ] && pushd $dir > /dev/null && \
    tmux new -s "$name" && \
    popd > /dev/null
}
