#!/bin/sh
# ALIASES FOR GIT
alias \
    gs="git status" \
    ga="git add" \
    gc="git commit" \
    gp="git push origin main" \
    gd="git diff" \
    gr="git remote -v" \
    gch="git checkout" \
    gl="git log" \
    gra="git remote add origin" \
    grv="git remote remove origin" \
    gi="git init"

# ALIASES FOR CONFIG
alias \
    cs="config status" \
    ca="config add" \
    cc="config commit" \
    cps="config push origin main" \
    cdf="config diff"

# EXTRA
alias \
    p='sudo pacman' \
    ls='ls --color=auto' \
    ll='ls -al --color=auto' \
    mi='sudo make clean install' \
    sc="cd ~/.local/bin" \
    dw="cd ~/suckless/dwm" \
    sk="cd ~/suckless" \
    config="/usr/bin/git --git-dir=$HOME/.dotfiles.git/ --work-tree=$HOME" \
    update="yay -Syu" \
    dac="source ../venv/bin/activate" \
    tmux="tmux -f $HOME/.config/tmux.conf"

se(){ 
    file=$(du -a $HOME/.local/bin/* $HOME/.config/* | awk '{ print $2 }' | grep -w -v "libreoffice\|coc" | fzf)
    [ "$file" ] && nvim $file
}
sf(){
    directory=$(du -a $HOME/.local/bin/* $HOME/.config/* | awk '{ print $2 }' | grep -w -v "libreoffice\|coc" | fzf)
    [ "$directory" ] && cd $directory
}
de() { 
    dir=$(ls -d -1 "$HOME/Documents/code/django/"* "$HOME/Documents/code/projects/"* "$HOME/Documents/code/learning/"* | fzf)
    name=$(echo $dir | awk -F "/" '{ print $NF }')
    [ "$dir" ] && pushd $dir > /dev/null && \
    tmux new-session -d -s "$name" && \
    tmux switch-client -t "$name" && \
    popd > /dev/null
}
