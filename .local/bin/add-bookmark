#!/bin/sh
read -p 'enter bookmark name: ' bookmark_name
read -p 'enter bookmark url: ' bookmark_url
printf "$bookmark_name $bookmark_url\n" >> $HOME/.local/share/bookmarks/bookmarks.txt
cd ~/.local/share/bookmarks
git add -A
git commit -m --no-gpg-sign "Added bookmark $bookmark_name"
git push origin main
